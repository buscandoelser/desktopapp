<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gestion.controllers.CobranzasController"
      styleClass="module-container"
      spacing="20">

    <!-- ── Encabezado ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="Cobranzas" styleClass="module-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ProgressIndicator fx:id="progressIndicator" prefWidth="28" prefHeight="28"
                           styleClass="progress-acento" visible="false"/>
        <Button fx:id="btnRegistrar"
                text="＋  Registrar cobro"
                onAction="#onRegistrar"
                styleClass="btn-primary"/>
    </HBox>

    <!-- ── Stat cards ─────────────────────────────────────────── -->
    <GridPane hgap="14" vgap="14">
        <columnConstraints>
            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="stat-card tone-success" spacing="6">
            <Label text="Cobrado este mes" styleClass="stat-label"/>
            <Label fx:id="lblCobrado"      text="—" styleClass="stat-value"/>
            <Label fx:id="lblCobradoDelta" text="" styleClass="stat-delta"/>
        </VBox>

        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="stat-card tone-warn" spacing="6">
            <Label text="Pendiente" styleClass="stat-label"/>
            <Label fx:id="lblPendiente"      text="—" styleClass="stat-value"/>
            <Label fx:id="lblPendienteDelta" text="" styleClass="stat-delta"/>
        </VBox>

        <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="stat-card tone-danger" spacing="6">
            <Label text="Vencido" styleClass="stat-label"/>
            <Label fx:id="lblVencido"      text="—" styleClass="stat-value"/>
            <Label fx:id="lblVencidoDelta" text="" styleClass="stat-delta"/>
        </VBox>

        <VBox GridPane.columnIndex="3" GridPane.rowIndex="0" styleClass="stat-card" spacing="6">
            <Label text="Tasa de cobranza" styleClass="stat-label"/>
            <Label fx:id="lblTasa"      text="—" styleClass="stat-value"/>
            <Label fx:id="lblTasaDelta" text="objetivo 90%" styleClass="stat-delta"/>
        </VBox>
    </GridPane>

    <!-- ── Barra de filtros ──────────────────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-bar">
        <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>

        <Label text="Buscar:" styleClass="filter-label"/>
        <TextField fx:id="txtBusqueda"
                   promptText="Nombre, legajo o concepto..."
                   prefWidth="280"
                   styleClass="input-field-sm"/>

        <Label text="Mes:" styleClass="filter-label"/>
        <ComboBox fx:id="cmbMes" prefWidth="150" styleClass="combo-field"/>

        <Label text="Estado:" styleClass="filter-label"/>
        <ComboBox fx:id="cmbEstado" prefWidth="140" styleClass="combo-field"/>

        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" text="Total: — movimientos" styleClass="label-secondary"/>
    </HBox>

    <!-- ── Tabla ─────────────────────────────────────────────── -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="0">
        <HBox styleClass="card-head">
            <Label text="Movimientos" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Exportar CSV" styleClass="btn-link" onAction="#onExportar"/>
        </HBox>
        <TableView fx:id="tablaCobranzas" VBox.vgrow="ALWAYS" styleClass="table-dark">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colFecha"    text="Fecha"    prefWidth="90"/>
                <TableColumn fx:id="colInterno"  text="Interno"  prefWidth="200"/>
                <TableColumn fx:id="colConcepto" text="Concepto" prefWidth="200"/>
                <TableColumn fx:id="colMonto"    text="Monto"    prefWidth="120"/>
                <TableColumn fx:id="colMetodo"   text="Método"   prefWidth="120"/>
                <TableColumn fx:id="colEstado"   text="Estado"   prefWidth="100"/>
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="100"/>
            </columns>
            <placeholder>
                <Label text="No hay movimientos para mostrar" styleClass="table-placeholder"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>
