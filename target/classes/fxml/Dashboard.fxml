<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gestion.controllers.DashboardController"
      styleClass="module-container"
      spacing="20">

    <!-- ── Encabezado ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="Panel general" styleClass="module-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblFecha" text="" styleClass="label-secondary"/>
    </HBox>

    <!-- ── Stat cards (2 columnas) ───────────────────────────── -->
    <GridPane hgap="14" vgap="14">
        <columnConstraints>
            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="50" hgrow="ALWAYS"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="stat-card tone-success" spacing="6">
            <Label text="Cobranzas del mes" styleClass="stat-label"/>
            <Label fx:id="lblCobranzasMes"   text="—" styleClass="stat-value"/>
            <Label fx:id="lblCobranzasDelta" text="" styleClass="stat-delta"/>
        </VBox>

        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="stat-card tone-danger" spacing="6">
            <Label text="Deuda total acumulada" styleClass="stat-label"/>
            <Label fx:id="lblPlazas"      text="—" styleClass="stat-value"/>
            <Label fx:id="lblPlazasDelta" text="" styleClass="stat-delta"/>
        </VBox>
    </GridPane>

    <!-- ── Fila inferior: cobranzas + 2 rings ────────────────── -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Cobranzas recientes -->
        <VBox HBox.hgrow="ALWAYS" styleClass="card" spacing="0">
            <HBox styleClass="card-head">
                <Label text="Cobranzas recientes" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Ver todas" styleClass="btn-link" onAction="#onVerCobranzas"/>
            </HBox>
            <VBox fx:id="listCobranzas" spacing="0"/>
        </VBox>

        <!-- Ring 1: Ocupación Casa Central -->
        <VBox styleClass="capacity-ring-card" alignment="TOP_CENTER" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="Ocupación Casa Central" styleClass="capacity-ring-title"/>
            </HBox>
            <Label text="camas ocupadas vs. capacidad total" styleClass="capacity-ring-hint"/>

            <StackPane fx:id="capacityRingHost" prefHeight="190" minHeight="190"/>

            <VBox spacing="8" maxWidth="Infinity">
                <HBox styleClass="capacity-legend-row">
                    <Region styleClass="capacity-legend-dot used"/>
                    <Label text="Ocupadas" styleClass="capacity-legend-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblOcupadasValor" text="—" styleClass="capacity-legend-value"/>
                </HBox>
                <HBox styleClass="capacity-legend-row">
                    <Region styleClass="capacity-legend-dot free"/>
                    <Label text="Libres" styleClass="capacity-legend-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblLibresValor" text="—" styleClass="capacity-legend-value"/>
                </HBox>
                <Label fx:id="lblCapacidadTotal" text="—" styleClass="capacity-total-label"/>
            </VBox>
        </VBox>

        <!-- Ring 2: Internos con deuda -->
        <VBox styleClass="capacity-ring-card" alignment="TOP_CENTER" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="Internos con deuda" styleClass="capacity-ring-title"/>
            </HBox>
            <Label text="deudores sobre el total de internos" styleClass="capacity-ring-hint"/>

            <StackPane fx:id="deudaRingHost" prefHeight="190" minHeight="190"/>

            <VBox spacing="8" maxWidth="Infinity">
                <HBox styleClass="capacity-legend-row">
                    <Region styleClass="capacity-legend-dot deuda"/>
                    <Label text="Con deuda" styleClass="capacity-legend-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblConDeudaValor" text="—" styleClass="capacity-legend-value"/>
                </HBox>
                <HBox styleClass="capacity-legend-row">
                    <Region styleClass="capacity-legend-dot al-dia"/>
                    <Label text="Al día" styleClass="capacity-legend-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblAlDiaValor" text="—" styleClass="capacity-legend-value"/>
                </HBox>
                <Label fx:id="lblTotalInternosDeuda" text="—" styleClass="capacity-total-label"/>
            </VBox>
        </VBox>

    </HBox>

</VBox>
