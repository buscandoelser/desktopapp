<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gestion.controllers.BajaModalController"
      styleClass="root-dark,form-container"
      spacing="0"
      prefWidth="480">

    <!-- ── Header ─────────────────────────────────────────────── -->
    <HBox styleClass="wizard-header" alignment="CENTER_LEFT" spacing="14">
        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
        <Label text="⚠" style="-fx-font-size:22px; -fx-text-fill:#EF4444;"/>
        <VBox spacing="3">
            <Label text="Dar de baja al interno" styleClass="wizard-step-title"/>
            <Label fx:id="lblNombre" text="" styleClass="label-secondary"/>
        </VBox>
    </HBox>

    <Separator/>

    <!-- ── Body ───────────────────────────────────────────────── -->
    <VBox spacing="18">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

        <VBox spacing="6">
            <Label text="TIPO DE EGRESO *" styleClass="input-label"/>
            <ComboBox fx:id="cmbTipo" maxWidth="Infinity" styleClass="combo-field"/>
        </VBox>

        <VBox spacing="6">
            <Label text="MOTIVO *" styleClass="input-label"/>
            <TextArea fx:id="txtMotivo"
                      promptText="Describí el motivo del egreso (obligatorio)"
                      prefRowCount="4"
                      wrapText="true"
                      styleClass="input-field"/>
        </VBox>

        <HBox styleClass="warn-box">
            <Label text="Esta acción cambiará el estado del interno. El legajo quedará registrado en el historial."
                   styleClass="warn-box-text" wrapText="true"/>
        </HBox>
    </VBox>

    <Separator/>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <HBox styleClass="wizard-footer" alignment="CENTER_RIGHT" spacing="12">
        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
        <Button text="CANCELAR" onAction="#onCancelar" styleClass="btn-ghost"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ProgressIndicator fx:id="progressIndicator" prefWidth="28" prefHeight="28"
                           styleClass="progress-acento" visible="false"/>
        <Button fx:id="btnConfirmar"
                text="CONFIRMAR BAJA"
                onAction="#onConfirmar"
                styleClass="btn-danger"/>
    </HBox>

</VBox>
