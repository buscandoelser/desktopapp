<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gestion.controllers.LoginController"
      styleClass="login-split-root"
      prefWidth="860" prefHeight="560">

    <!-- PANEL IZQUIERDO — Formulario -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="430" styleClass="login-left-panel">

        <!-- Decoración esquinas -->
        <Region styleClass="login-deco-tl" StackPane.alignment="TOP_LEFT"
                prefWidth="110" prefHeight="110"/>
        <Region styleClass="login-deco-br" StackPane.alignment="BOTTOM_RIGHT"
                prefWidth="90" prefHeight="90"/>

        <!-- Contenido centrado -->
        <VBox alignment="CENTER" spacing="24" styleClass="login-left-form">

            <!-- Logo -->
            <ImageView fitWidth="140" preserveRatio="true" smooth="true">
                <image>
                    <Image url="@../logo-login.jpeg"/>
                </image>
            </ImageView>

            <!-- Campo usuario -->
            <TextField fx:id="txtUsuario"
                       promptText="Usuario"
                       styleClass="login-input"
                       maxWidth="300"/>

            <!-- Campo contraseña -->
            <StackPane maxWidth="300">
                <PasswordField fx:id="txtPassword"
                               promptText="Contraseña"
                               styleClass="login-input"/>
                <TextField fx:id="txtPasswordVisible"
                           promptText="Contraseña"
                           styleClass="login-input"/>
            </StackPane>

            <!-- Checkbox oculto — requerido por el controlador -->
            <CheckBox fx:id="chkMostrarPassword"
                      visible="false" managed="false"
                      onAction="#onTogglePassword"/>

            <!-- Mensaje de error -->
            <Label fx:id="lblError"
                   styleClass="login-error"
                   wrapText="true"
                   maxWidth="300"/>

            <!-- Botón -->
            <Button fx:id="btnLogin"
                    text="Iniciar Sesión"
                    onAction="#onLogin"
                    styleClass="login-btn"
                    prefWidth="300"
                    defaultButton="true"/>

            <!-- Spinner de carga -->
            <ProgressIndicator fx:id="progressIndicator"
                               prefWidth="32" prefHeight="32"
                               styleClass="login-progress"/>

        </VBox>
    </StackPane>

    <!-- PANEL DERECHO — Imagen con overlay dorado -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="430" styleClass="login-right-panel">

        <!-- Imagen de fondo -->
        <ImageView fitWidth="430" fitHeight="560">
            <image>
                <Image url="@../login-bg.jpeg"/>
            </image>
        </ImageView>



    </StackPane>

</HBox>
