<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gestion.controllers.InternosController"
      styleClass="module-container"
      spacing="20">

    <!-- ── Título del módulo ─────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="Gestión de Internos" styleClass="module-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ProgressIndicator fx:id="progressIndicator" prefWidth="28" prefHeight="28"
                           styleClass="progress-acento"/>
        <Button fx:id="btnNuevo"
                text="＋  NUEVO INTERNO"
                onAction="#onNuevoInterno"
                styleClass="btn-primary"/>
    </HBox>

    <!-- ── Barra de filtros ──────────────────────────────────── -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-bar">
        <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>

        <Label text="Buscar:" styleClass="filter-label"/>
        <TextField fx:id="txtBusqueda"
                   promptText="Nombre, apellido, DNI o legajo..."
                   prefWidth="280"
                   styleClass="input-field-sm"/>

        <Label text="Estado:" styleClass="filter-label"/>
        <ComboBox fx:id="cmbEstado" prefWidth="150" styleClass="combo-field"/>

        <Button text="🔍 Buscar" onAction="#onBuscar" styleClass="btn-secondary"/>

        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" text="Total: — registros" styleClass="label-secondary"/>
    </HBox>

    <!-- ── Tabla ─────────────────────────────────────────────── -->
    <TableView fx:id="tablaInternos" VBox.vgrow="ALWAYS" styleClass="table-dark">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_FLEX_LAST_COLUMN"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colLegajo"       text="Legajo"         prefWidth="160"/>
            <TableColumn fx:id="colNombre"        text="Nombre completo" prefWidth="220"/>
            <TableColumn fx:id="colDni"           text="DNI"            prefWidth="110"/>
            <TableColumn fx:id="colEstado"        text="Estado"         prefWidth="100"/>
            <TableColumn fx:id="colIngreso"       text="Ingreso"        prefWidth="100"/>
            <TableColumn fx:id="colTipoPago"      text="Tipo pago"      prefWidth="100"/>
            <TableColumn fx:id="colJudicializado" text="Judicial."      prefWidth="80"/>
            <TableColumn fx:id="colAcciones"      text="Acciones"       prefWidth="200"/>
        </columns>
        <placeholder>
            <Label text="No hay internos que coincidan con el filtro" styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

</VBox>
