<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="rootPane"
            fx:controller="com.gestion.controllers.MainController"
            styleClass="root-dark"
            prefWidth="1280" prefHeight="800">

    <!-- ── HEADER SUPERIOR (64px) ─────────────────────────────────────── -->
    <top>
        <HBox styleClass="header" prefHeight="64" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets left="24" right="24"/></padding>

            <Label text="Buscando El Ser" styleClass="header-logo"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Capacity chip -->
            <HBox styleClass="header-capacity-chip" alignment="CENTER_LEFT" spacing="8">
                <Region styleClass="status-dot"/>
                <VBox spacing="3" alignment="CENTER_LEFT">
                    <Label fx:id="lblCapacidadMeta" text="Cargando..." styleClass="header-cap-meta"/>
                    <ProgressBar fx:id="pbCapacidad" progress="0"
                                 prefWidth="88" prefHeight="4"
                                 styleClass="capacity-bar-mini"/>
                </VBox>
            </HBox>

            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="lblUsuarioNombre" text="Usuario" styleClass="header-user-name"/>
                <Label fx:id="lblUsuarioRol"    text="Rol"     styleClass="header-user-rol"/>
            </VBox>

            <Button text="Salir"
                    onAction="#onCerrarSesion"
                    styleClass="btn-logout"/>
        </HBox>
    </top>

    <!-- ── ÁREA DE CONTENIDO ──────────────────────────────────────────── -->
    <center>
        <StackPane fx:id="contenidoPrincipal" styleClass="content-area">
            <padding><Insets top="24" right="32" bottom="16" left="32"/></padding>
        </StackPane>
    </center>

    <!-- ── DOCK INFERIOR — inyectado programáticamente en MainController ── -->

</BorderPane>
