<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gestion.controllers.MainController"
            styleClass="root-dark"
            prefWidth="1280" prefHeight="800">

    <!-- ── HEADER SUPERIOR (64px) ────────────────────────────── -->
    <top>
        <HBox styleClass="header" prefHeight="64" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets left="24" right="24"/></padding>

            <Label text="⚕ Sistema de Internos" styleClass="header-logo"/>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label fx:id="lblUsuarioNombre" text="Usuario" styleClass="header-user-name"/>
                <Label fx:id="lblUsuarioRol"    text="Rol"     styleClass="header-user-rol"/>
            </VBox>

            <Button text="⏻  CERRAR SESIÓN"
                    onAction="#onCerrarSesion"
                    styleClass="btn-logout"/>
        </HBox>
    </top>

    <!-- ── SIDEBAR IZQUIERDO (240px) ─────────────────────────── -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="240" spacing="4">
            <padding><Insets top="24" bottom="24" left="12" right="12"/></padding>

            <Label text="NAVEGACIÓN" styleClass="sidebar-section-label"/>

            <Button fx:id="btnInternos"
                    text="👤  Internos"
                    onAction="#onInternos"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity"/>

            <Button fx:id="btnCobranzas"
                    text="💰  Cobranzas"
                    onAction="#onCobranzas"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity"/>

            <Button fx:id="btnReportes"
                    text="📊  Reportes"
                    onAction="#onReportes"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator styleClass="sidebar-separator"/>

            <Button fx:id="btnConfiguracion"
                    text="⚙  Configuración"
                    onAction="#onConfiguracion"
                    styleClass="sidebar-btn"
                    maxWidth="Infinity"/>

        </VBox>
    </left>

    <!-- ── ÁREA DE CONTENIDO ─────────────────────────────────── -->
    <center>
        <StackPane fx:id="contenidoPrincipal" styleClass="content-area">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
        </StackPane>
    </center>

</BorderPane>
